# LLM Provider Selection
# Options: gemini, anthropic, zai, minimax
LLM_PROVIDER="gemini"

# LLM API Keys (configure based on your selected provider)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"
ZAI_API_KEY="MY_ZAI_API_KEY"
MINIMAX_API_KEY="MY_MINIMAX_API_KEY"

# Redis Configuration (for session persistence)
REDIS_URL="redis://redis:6379"

# Session Secret (for cookie-session)
SESSION_SECRET="change-this-to-a-random-secret-string"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Jira OAuth Credentials
JIRA_CLIENT_ID="MY_JIRA_CLIENT_ID"
JIRA_CLIENT_SECRET="MY_JIRA_CLIENT_SECRET"
